# lx-agent configuration
canvas:
  url: "myetl.snu.ac.kr"            # Canvas LMS base URL (was learningx.snu.ac.kr)
  token: ""                          # API access token (Settings → New Access Token)
  session_cookie: ""                 # Alternative: Normandy session cookie (for instances that reject Bearer tokens)

monitor:
  poll_interval: "10m"               # How often to check for updates
  summarize_new: false               # Reserved (no built-in summarizer provider)
  deadline_alerts: [3, 1, 0]         # Alert N days before due date
  state_path: "lx-state.json"        # State file for tracking seen items
  # courses: [12345, 67890]          # Filter specific course IDs (empty = all)

notifier:
  provider: "stdout"                 # stdout | telegram | (extensible)
  telegram:
    bot_token: ""                    # Telegram bot token from @BotFather
    chat_id: ""                      # Optional: if empty, lookup from database by canvas token

database:
  url: ""                            # Optional: Postgres URL for canvas-token -> chat-id binding
